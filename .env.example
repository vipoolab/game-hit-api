# Trino connection (required)
TRINO_HOST=trino.example.com
TRINO_PORT=443
TRINO_USER=your_username
TRINO_PASSWORD=your_password
TRINO_CATALOG=delta
TRINO_HTTP_SCHEME=https
TRINO_REQUEST_TIMEOUT=120

# API settings (optional — defaults shown)
API_HOST=0.0.0.0
API_PORT=8000

# Refresh window in days (default 30 = "last month")
HIT_WINDOW_DAYS=30

# Cron schedule for refresh — every hour at minute 5 by default
HIT_REFRESH_CRON_HOUR=*
HIT_REFRESH_CRON_MINUTE=5

# How many top games to keep per provider in the cache (0 = all)
HIT_GAMES_PER_PROVIDER=50

# Cache file path (relative to project root or absolute)
HIT_CACHE_FILE=data/hits.json

# Optional shared secret to protect POST /refresh (leave blank to disable auth)
REFRESH_TOKEN=
