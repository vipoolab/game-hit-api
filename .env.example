# Trino connection (required)
TRINO_HOST=trino.example.com
TRINO_PORT=443
TRINO_USER=your_username
TRINO_PASSWORD=your_password
TRINO_CATALOG=delta
TRINO_HTTP_SCHEME=https
TRINO_REQUEST_TIMEOUT=120

# API settings (optional — defaults shown)
API_HOST=0.0.0.0
API_PORT=8000

# Refresh window in days (default 30 = "last month")
HIT_WINDOW_DAYS=30

# Cron schedule for refresh — once a day at 03:05 UTC (= 10:05 Bangkok)
# by default. Off-peak for Trino, ~24h freshness is fine for "hit list".
# Examples:
#   daily 10:05 BKK  → HOUR=3  MINUTE=5
#   every 6 hours    → HOUR=*/6 MINUTE=5
#   every hour       → HOUR=*  MINUTE=5
HIT_REFRESH_CRON_HOUR=3
HIT_REFRESH_CRON_MINUTE=5

# How many top games to keep per provider in the cache (0 = all)
HIT_GAMES_PER_PROVIDER=50

# Cache file path (relative to project root or absolute)
HIT_CACHE_FILE=data/hits.json

# Shared secret to protect POST /refresh.
# Local dev: ปล่อยว่างได้ (เปิดให้ใช้ฟรี + log warning)
# Production (Railway/Heroku/Fly): ถ้าไม่ตั้ง endpoint /refresh จะ disabled อัตโนมัติ
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
REFRESH_TOKEN=

# CORS allowed origins — comma-separated list, * = all (default)
# เช่น CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=*
